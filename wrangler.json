{
	"name": "melody",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "melody-db",
			"database_id": "f0aa54e8-e5ea-4791-975a-ff235ec9f872",
			"migrations_dir": "migrations"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "melody-media"
		}
	],
	"vars": {
		"TURNSTILE_SITE_KEY": "0x4AAAAAADsCJQGf71UUvbXG"
	}
}
