---
import Base from "../../layouts/Base.astro";
import {
	getDb,
	getPerformanceBySlug,
	performersForPerformance,
	listPerformancePhotos,
} from "../../lib/db";
import { mediaUrl } from "../../lib/media";

export const prerender = false;

const { slug } = Astro.params;
const db = getDb(Astro.locals);
const performance = slug ? await getPerformanceBySlug(db, slug) : null;

if (!performance) {
	return new Response("Not found", { status: 404 });
}

const performers = await performersForPerformance(db, performance.id);
const photos = await listPerformancePhotos(db, performance.id);

function fmtDate(d: string | null) {
	if (!d) return "";
	return new Date(d).toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base title={performance.title} description={performance.summary ?? undefined}>
	<article>
		{performance.cover_key && <img class="cover" src={mediaUrl(performance.cover_key)} alt="" />}
		<h1>{performance.title}</h1>
		<p class="meta">
			{[performance.venue, performance.location].filter(Boolean).join(", ")}
			{performance.event_date && ` · ${fmtDate(performance.event_date)}`}
		</p>
		{performance.description && <p class="prose-text">{performance.description}</p>}

		{
			photos.length > 0 && (
				<section class="gallery">
					{photos.map((photo) => (
						<figure>
							<img src={mediaUrl(photo.photo_key)} alt={photo.caption ?? ""} loading="lazy" />
							{photo.caption && <figcaption>{photo.caption}</figcaption>}
						</figure>
					))}
				</section>
			)
		}

		{
			performers.length > 0 && (
				<>
					<h2>Performers</h2>
					<ul class="performer-list">
						{performers.map((person) => (
							<li>
								<a href="/performers">{person.name}</a>
								{person.instrument && <span class="muted"> — {person.instrument}</span>}
							</li>
						))}
					</ul>
				</>
			)
		}

		<p><a href="/performances">← Back to all performances</a></p>
	</article>
</Base>

<style>
	.cover {
		width: 100%;
		max-height: 420px;
		object-fit: cover;
		border-radius: 12px;
		margin-bottom: 1em;
	}
	.meta {
		color: rgb(var(--gray));
		margin-bottom: 1.5em;
	}
	.prose-text {
		font-size: 1.1em;
	}
	.performer-list {
		padding-left: 1.2em;
	}
	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
		gap: 0.8em;
		margin: 1.5em 0;
	}
	.gallery figure {
		margin: 0;
	}
	.gallery img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: 8px;
	}
	.gallery figcaption {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin-top: 0.2em;
	}
</style>
