---
import Base from "../layouts/Base.astro";
import { getDb, listTeam } from "../lib/db";
import { mediaUrl } from "../lib/media";

export const prerender = false;

const db = getDb(Astro.locals);
const team = await listTeam(db);
---

<Base wide title="About Us">
	<h1>About Us</h1>
	<div class="prose-text">
		<p>
			Melody for Medicine is a student-run group of teen musicians who bring live performances to
			senior living communities, care homes, and local events. What started as a few friends
			playing at a single retirement home has grown into a roster of performers playing across the
			area.
		</p>
		<p>
			Our mission is simple: share the joy of live music with audiences who don't often get to
			experience it, while giving young musicians a meaningful reason to keep playing. Every
			performance is free for the communities we visit.
		</p>
	</div>

	<h2>Our Team</h2>
	<div class="grid">
		{
			team.map((member) => (
				<div class="card">
					{member.photo_key && <img src={mediaUrl(member.photo_key)} alt={member.name} />}
					<div class="card-body">
						<h3>{member.name}</h3>
						{member.role && <p class="muted role">{member.role}</p>}
						{member.bio && <p>{member.bio}</p>}
					</div>
				</div>
			))
		}
	</div>

	<section class="band">
		<h2>Get in touch</h2>
		<p>
			Interested in hosting us, volunteering, or partnering? Use the links below — we read every
			message.
		</p>
		<div class="cta-row">
			<a class="btn btn-primary" href="/request-performance">Request a Performance</a>
			<a class="btn btn-secondary" href="/get-involved">Get Involved</a>
		</div>
	</section>
</Base>

<style>
	.prose-text {
		font-size: 1.1em;
		max-width: 65ch;
		margin-bottom: 2em;
	}
	.role {
		font-weight: 700;
		color: var(--accent);
	}
	.card-body h3 {
		margin: 0 0 0.1em;
	}
	.band {
		text-align: center;
		background: var(--brand-grad);
		border-radius: var(--radius-lg);
		padding: 3em 1.5em;
		margin-top: 3.5em;
		color: white;
		box-shadow: var(--shadow-lg);
	}
	.band :global(h2) {
		color: white;
	}
	.band p {
		max-width: 50ch;
		margin: 0.5em auto 1.5em;
		color: rgba(255, 255, 255, 0.9);
	}
	.band .btn-primary {
		background: white;
		color: var(--accent-dark);
		box-shadow: 0 6px 16px rgba(0, 0, 0, 0.18);
	}
	.band .btn-primary:hover {
		color: var(--accent-dark);
	}
	.band .btn-secondary {
		background: rgba(255, 255, 255, 0.12);
		color: white;
		border-color: rgba(255, 255, 255, 0.5);
	}
	.band .btn-secondary:hover {
		color: white;
		border-color: white;
	}
	.cta-row {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
	}
</style>
