---
import Admin from "../../layouts/Admin.astro";
import { uploadImage, slugify } from "../../lib/admin";
import { getDb } from "../../lib/db";
import { mediaUrl } from "../../lib/media";

export const prerender = false;

const db = getDb(Astro.locals);
const bucket = Astro.locals.runtime?.env?.MEDIA;

let error: string | null = null;

if (Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action"));
	try {
		if (action === "create") {
			const name = String(form.get("name") ?? "").trim();
			if (!name) throw new Error("Name is required.");
			const photoKey = await uploadImage(bucket, form.get("photo"), "performers");
			await db
				.prepare(
					`INSERT INTO performers (name, slug, instrument, bio, photo_key, sort_order)
					 VALUES (?, ?, ?, ?, ?, ?)`,
				)
				.bind(
					name,
					slugify(name) || `performer-${Date.now()}`,
					String(form.get("instrument") ?? "").trim() || null,
					String(form.get("bio") ?? "").trim() || null,
					photoKey,
					parseInt(String(form.get("sort_order") ?? "0"), 10) || 0,
				)
				.run();
		} else if (action === "toggle") {
			const id = parseInt(String(form.get("id")), 10);
			await db
				.prepare("UPDATE performers SET published = 1 - published WHERE id = ?")
				.bind(id)
				.run();
		} else if (action === "delete") {
			const id = parseInt(String(form.get("id")), 10);
			await db.prepare("DELETE FROM performers WHERE id = ?").bind(id).run();
		}
		return Astro.redirect("/admin/performers");
	} catch (e) {
		error = e instanceof Error ? e.message : "Something went wrong.";
	}
}

const { results: performers } = await db
	.prepare("SELECT * FROM performers ORDER BY sort_order, name")
	.all();
---

<Admin title="Performers">
	<h1>Performers</h1>
	{error && <div class="notice notice-error">{error}</div>}

	<div class="layout">
		<section>
			<table class="list">
				<tbody>
					{
						performers.map((p: any) => (
							<tr>
								<td>
									<img class="thumb" src={mediaUrl(p.photo_key)} alt="" />
								</td>
								<td>
									<strong>{p.name}</strong>
									<div class="muted small">{p.instrument}</div>
								</td>
								<td>
									<span class={p.published ? "on" : "off"}>
										{p.published ? "visible" : "hidden"}
									</span>
								</td>
								<td class="actions">
									<a class="link-btn" href={`/admin/performers/${p.id}`}>Edit</a>
									<form method="POST">
										<input type="hidden" name="action" value="toggle" />
										<input type="hidden" name="id" value={p.id} />
										<button class="link-btn" type="submit">
											{p.published ? "Hide" : "Show"}
										</button>
									</form>
									<form method="POST" onsubmit="return confirm('Delete this performer?')">
										<input type="hidden" name="action" value="delete" />
										<input type="hidden" name="id" value={p.id} />
										<button class="link-btn danger" type="submit">Delete</button>
									</form>
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
			{performers.length === 0 && <p class="muted">No performers yet.</p>}
		</section>

		<aside class="form-card">
			<h2>Add performer</h2>
			<form method="POST" enctype="multipart/form-data">
				<input type="hidden" name="action" value="create" />
				<div class="field">
					<label for="name">Name *</label>
					<input id="name" name="name" required />
				</div>
				<div class="field">
					<label for="instrument">Instrument</label>
					<input id="instrument" name="instrument" />
				</div>
				<div class="field">
					<label for="bio">Bio</label>
					<textarea id="bio" name="bio" rows="3"></textarea>
				</div>
				<div class="field">
					<label for="photo">Photo</label>
					<input id="photo" name="photo" type="file" accept="image/*" />
					<span class="hint">JPG, PNG, WebP or GIF, under 5 MB.</span>
				</div>
				<div class="field">
					<label for="sort_order">Sort order</label>
					<input id="sort_order" name="sort_order" type="number" value="0" />
				</div>
				<button class="btn btn-primary" type="submit">Add performer</button>
			</form>
		</aside>
	</div>
</Admin>

<style>
	.layout {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2em;
		align-items: start;
	}
	.list {
		background: white;
		border-radius: 12px;
		box-shadow: 0 2px 8px rgba(var(--gray), 18%);
		border-collapse: collapse;
		overflow: hidden;
	}
	.list td {
		padding: 0.6em 0.8em;
		border-bottom: 1px solid rgb(var(--gray-light));
		vertical-align: middle;
	}
	.thumb {
		width: 48px;
		height: 48px;
		object-fit: cover;
		border-radius: 8px;
	}
	.small {
		font-size: 0.8em;
	}
	.on {
		color: #1c6b3a;
		font-weight: 700;
	}
	.off {
		color: rgb(var(--gray));
	}
	.actions {
		display: flex;
		gap: 0.8em;
	}
	.link-btn {
		background: none;
		border: none;
		color: var(--accent);
		cursor: pointer;
		padding: 0;
		font-size: 0.9em;
		text-decoration: none;
	}
	.link-btn.danger {
		color: #9b1c1c;
	}
	.form-card {
		background: white;
		border-radius: 12px;
		padding: 1.2em;
		box-shadow: 0 2px 8px rgba(var(--gray), 18%);
	}
	.form-card h2 {
		font-size: 1.3em;
		margin-top: 0;
	}
	@media (max-width: 800px) {
		.layout {
			grid-template-columns: 1fr;
		}
	}
</style>
