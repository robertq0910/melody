---
import Admin from "../../../layouts/Admin.astro";
import { uploadImage, deleteImage, slugify } from "../../../lib/admin";
import {
	getDb,
	getPerformanceById,
	performerIdsForPerformance,
	listPerformancePhotos,
} from "../../../lib/db";
import { mediaUrl } from "../../../lib/media";

export const prerender = false;

const db = getDb(Astro.locals);
const bucket = Astro.locals.runtime?.env?.MEDIA;
const id = parseInt(Astro.params.id ?? "", 10);

let error: string | null = null;

if (Number.isFinite(id) && Astro.request.method === "POST") {
	const form = await Astro.request.formData();
	const action = String(form.get("action"));
	try {
		const existing = await getPerformanceById(db, id);
		if (!existing) throw new Error("Performance not found.");

		if (action === "update") {
			const title = String(form.get("title") ?? "").trim();
			if (!title) throw new Error("Title is required.");

			let coverKey = existing.cover_key;
			const newCover = await uploadImage(bucket, form.get("cover"), "performances");
			if (newCover) {
				await deleteImage(bucket, existing.cover_key);
				coverKey = newCover;
			} else if (form.get("remove_cover")) {
				await deleteImage(bucket, existing.cover_key);
				coverKey = null;
			}

			await db
				.prepare(
					`UPDATE performances
					 SET title = ?, slug = ?, venue = ?, location = ?, event_date = ?,
					     summary = ?, description = ?, cover_key = ?, published = ?
					 WHERE id = ?`,
				)
				.bind(
					title,
					slugify(title) || existing.slug,
					String(form.get("venue") ?? "").trim() || null,
					String(form.get("location") ?? "").trim() || null,
					String(form.get("event_date") ?? "").trim() || null,
					String(form.get("summary") ?? "").trim() || null,
					String(form.get("description") ?? "").trim() || null,
					coverKey,
					form.get("published") ? 1 : 0,
					id,
				)
				.run();

			// Reset and re-link performers.
			await db.prepare("DELETE FROM performance_performers WHERE performance_id = ?").bind(id).run();
			const performerIds = form.getAll("performers").map((v) => parseInt(String(v), 10));
			for (const pid of performerIds) {
				if (Number.isFinite(pid)) {
					await db
						.prepare(
							"INSERT OR IGNORE INTO performance_performers (performance_id, performer_id) VALUES (?, ?)",
						)
						.bind(id, pid)
						.run();
				}
			}
		} else if (action === "add_photo") {
			const photoKey = await uploadImage(bucket, form.get("photo"), "gallery");
			if (!photoKey) throw new Error("Choose an image to upload.");
			await db
				.prepare(
					"INSERT INTO performance_photos (performance_id, photo_key, caption, sort_order) VALUES (?, ?, ?, ?)",
				)
				.bind(
					id,
					photoKey,
					String(form.get("caption") ?? "").trim() || null,
					parseInt(String(form.get("sort_order") ?? "0"), 10) || 0,
				)
				.run();
		} else if (action === "delete_photo") {
			const photoId = parseInt(String(form.get("photo_id")), 10);
			const photo = await db
				.prepare("SELECT photo_key FROM performance_photos WHERE id = ? AND performance_id = ?")
				.bind(photoId, id)
				.first<{ photo_key: string }>();
			if (photo) {
				await deleteImage(bucket, photo.photo_key);
				await db.prepare("DELETE FROM performance_photos WHERE id = ?").bind(photoId).run();
			}
		}
		return Astro.redirect(`/admin/performances/${id}`);
	} catch (e) {
		error = e instanceof Error ? e.message : "Something went wrong.";
	}
}

const performance = Number.isFinite(id) ? await getPerformanceById(db, id) : null;
if (!performance) {
	return new Response("Performance not found", { status: 404 });
}

const linkedIds = new Set(await performerIdsForPerformance(db, id));
const photos = await listPerformancePhotos(db, id);
const { results: allPerformers } = await db
	.prepare("SELECT id, name FROM performers ORDER BY sort_order, name")
	.all();
---

<Admin title={`Edit ${performance.title}`}>
	<p><a href="/admin/performances">← Back to performances</a></p>
	<h1>Edit performance</h1>
	{error && <div class="notice notice-error">{error}</div>}

	<div class="cols">
		<form method="POST" enctype="multipart/form-data" class="edit-form">
			<input type="hidden" name="action" value="update" />
			<div class="field">
				<label for="title">Title *</label>
				<input id="title" name="title" required value={performance.title} />
			</div>
			<div class="row">
				<div class="field">
					<label for="venue">Venue</label>
					<input id="venue" name="venue" value={performance.venue ?? ""} />
				</div>
				<div class="field">
					<label for="location">Location</label>
					<input id="location" name="location" value={performance.location ?? ""} />
				</div>
			</div>
			<div class="field">
				<label for="event_date">Date</label>
				<input id="event_date" name="event_date" type="date" value={performance.event_date ?? ""} />
			</div>
			<div class="field">
				<label for="summary">Summary</label>
				<input id="summary" name="summary" value={performance.summary ?? ""} />
			</div>
			<div class="field">
				<label for="description">Description</label>
				<textarea id="description" name="description" rows="5">{performance.description ?? ""}</textarea>
			</div>
			<div class="field">
				<label>Current cover</label>
				{
					performance.cover_key ? (
						<div class="current">
							<img src={mediaUrl(performance.cover_key)} alt="" />
							<label class="inline">
								<input type="checkbox" name="remove_cover" /> Remove cover
							</label>
						</div>
					) : (
						<p class="muted">No cover.</p>
					)
				}
			</div>
			<div class="field">
				<label for="cover">Replace cover</label>
				<input id="cover" name="cover" type="file" accept="image/*" />
			</div>
			<div class="field">
				<label for="performers">Performers</label>
				<select id="performers" name="performers" multiple size="6">
					{
						allPerformers.map((p: any) => (
							<option value={p.id} selected={linkedIds.has(p.id)}>
								{p.name}
							</option>
						))
					}
				</select>
				<span class="hint">Ctrl/Cmd-click to select several.</span>
			</div>
			<div class="field">
				<label class="inline">
					<input type="checkbox" name="published" checked={performance.published === 1} /> Visible on
					site
				</label>
			</div>
			<button class="btn btn-primary" type="submit">Save changes</button>
		</form>

		<aside class="gallery-admin">
			<h2>Photo gallery</h2>
			<div class="gallery">
				{
					photos.map((photo) => (
						<div class="g-item">
							<img src={mediaUrl(photo.photo_key)} alt={photo.caption ?? ""} />
							{photo.caption && <span class="cap">{photo.caption}</span>}
							<form method="POST" onsubmit="return confirm('Delete this photo?')">
								<input type="hidden" name="action" value="delete_photo" />
								<input type="hidden" name="photo_id" value={photo.id} />
								<button class="link-btn danger" type="submit">Delete</button>
							</form>
						</div>
					))
				}
			</div>
			{photos.length === 0 && <p class="muted">No gallery photos yet.</p>}

			<form method="POST" enctype="multipart/form-data" class="add-photo">
				<input type="hidden" name="action" value="add_photo" />
				<div class="field">
					<label for="photo">Add photo</label>
					<input id="photo" name="photo" type="file" accept="image/*" required />
				</div>
				<div class="field">
					<label for="caption">Caption</label>
					<input id="caption" name="caption" />
				</div>
				<div class="field">
					<label for="sort_order">Sort order</label>
					<input id="sort_order" name="sort_order" type="number" value="0" />
				</div>
				<button class="btn btn-secondary" type="submit">Upload photo</button>
			</form>
		</aside>
	</div>
</Admin>

<style>
	.cols {
		display: grid;
		grid-template-columns: 1fr 320px;
		gap: 2em;
		align-items: start;
	}
	.current img {
		width: 160px;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		border-radius: 8px;
		display: block;
		margin-bottom: 0.4em;
	}
	.inline {
		display: inline-flex !important;
		align-items: center;
		gap: 0.4em;
		font-weight: 400 !important;
	}
	.gallery-admin {
		background: white;
		border-radius: 12px;
		padding: 1.2em;
		box-shadow: 0 2px 8px rgba(var(--gray), 18%);
	}
	.gallery-admin h2 {
		margin-top: 0;
		font-size: 1.3em;
	}
	.gallery {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.8em;
		margin-bottom: 1em;
	}
	.g-item img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: 8px;
	}
	.g-item .cap {
		font-size: 0.8em;
		color: rgb(var(--gray));
		display: block;
	}
	.link-btn {
		background: none;
		border: none;
		color: var(--accent);
		cursor: pointer;
		padding: 0;
		font-size: 0.85em;
	}
	.link-btn.danger {
		color: #9b1c1c;
	}
	.add-photo {
		border-top: 1px solid rgb(var(--gray-light));
		padding-top: 1em;
	}
	@media (max-width: 820px) {
		.cols {
			grid-template-columns: 1fr;
		}
	}
</style>
