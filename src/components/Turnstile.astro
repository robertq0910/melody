---
// Renders the Cloudflare Turnstile widget. The site key is a public var.
const siteKey = Astro.locals.runtime?.env?.TURNSTILE_SITE_KEY ?? "1x00000000000000000000AA";
---

<div class="cf-turnstile" data-sitekey={siteKey}></div>
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
