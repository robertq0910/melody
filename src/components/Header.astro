---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE, NAV_LINKS } from "../consts";
---

<header>
	<nav>
		<a class="site-title" href="/">
			<span class="logo-mark" aria-hidden="true">♪</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
		<div class="internal-links">
			{NAV_LINKS.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(255, 255, 255, 0.78);
		backdrop-filter: saturate(180%) blur(12px);
		-webkit-backdrop-filter: saturate(180%) blur(12px);
		border-bottom: 1px solid rgba(var(--gray-light), 0.9);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		max-width: 1100px;
		margin: 0 auto;
	}
	.site-title {
		display: flex;
		align-items: center;
		gap: 0.5em;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1.2em;
		letter-spacing: -0.02em;
		color: rgb(var(--black));
		text-decoration: none;
		padding: 0.7em 0;
	}
	.logo-mark {
		display: grid;
		place-items: center;
		width: 1.6em;
		height: 1.6em;
		border-radius: 50%;
		background: var(--brand-grad);
		color: white;
		font-size: 0.85em;
		box-shadow: 0 4px 10px rgba(124, 58, 237, 0.35);
	}
	.logo-text {
		background: var(--brand-grad);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.15em;
	}
	nav :global(a) {
		padding: 0.55em 0.85em;
		margin: 0.3em 0;
		color: rgb(var(--gray-dark));
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.95em;
		text-decoration: none;
		transition:
			background 0.18s var(--ease),
			color 0.18s var(--ease);
	}
	nav :global(a:hover) {
		background: rgba(var(--gray-light), 0.7);
		color: var(--accent);
	}
	nav :global(a.active) {
		text-decoration: none;
		background: var(--brand-grad-soft);
		color: var(--accent-dark);
	}
	.menu-toggle {
		display: none;
		font-size: 1.4em;
		background: none;
		border: none;
		cursor: pointer;
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 760px) {
		.menu-toggle {
			display: block;
		}
		.internal-links {
			flex-basis: 100%;
			flex-direction: column;
			display: none;
			padding-bottom: 0.5em;
		}
		.internal-links.open {
			display: flex;
		}
	}
</style>
<script>
	const toggle = document.querySelector(".menu-toggle");
	const links = document.querySelector(".internal-links");
	toggle?.addEventListener("click", () => {
		const open = links?.classList.toggle("open");
		toggle.setAttribute("aria-expanded", String(!!open));
	});
</script>
