---
import { SITE_TITLE } from "../consts";
const today = new Date();
---

<footer>
	<a class="footer-brand" href="/">
		<span class="logo-mark" aria-hidden="true">♪</span>
		<span class="logo-text">{SITE_TITLE}</span>
	</a>
	<div class="footer-links">
		<a href="/about">About Us</a>
		<a href="/request-performance">Request a Performance</a>
		<a href="/get-involved">Get Involved</a>
		<a href="/contact">Contact</a>
	</div>
	<p class="copy">&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
</footer>
<style>
	footer {
		margin-top: 3em;
		padding: 3em 1em 4em 1em;
		background: linear-gradient(180deg, transparent, rgba(var(--gray-light), 0.5));
		border-top: 1px solid rgba(var(--gray-light), 0.9);
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1.15em;
		letter-spacing: -0.02em;
		text-decoration: none;
		margin-bottom: 1.1em;
	}
	.logo-mark {
		display: grid;
		place-items: center;
		width: 1.6em;
		height: 1.6em;
		border-radius: 50%;
		background: var(--brand-grad);
		color: white;
		font-size: 0.85em;
		box-shadow: 0 4px 10px rgba(124, 58, 237, 0.35);
	}
	.logo-text {
		background: var(--brand-grad);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1.25em;
		margin-bottom: 1em;
	}
	.footer-links a {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		transition: color 0.18s var(--ease);
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.copy {
		font-size: 0.9em;
		margin: 0;
	}
</style>
