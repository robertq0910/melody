---
// A Leaflet + OpenStreetMap map of performance locations.
// Leaflet is loaded from a CDN (no API key, no billing). Points come from
// /api/performance-locations.json and are drawn as colored pins: upcoming vs.
// recent. The whole section hides itself if there are no resolvable locations.
interface Props {
	title?: string;
}
const { title = "Where we play" } = Astro.props;
---

<section class="map-section" aria-label="Map of performance locations">
	<div class="map-head">
		<h2>{title}</h2>
		<div class="legend" aria-hidden="true">
			<span class="legend-item">
				<svg class="pin up" width="18" height="24" viewBox="0 0 24 32" aria-hidden="true">
					<path d="M12 31C12 31 22 19 22 11A10 10 0 1 0 2 11C2 19 12 31 12 31Z" stroke="#fff" stroke-width="2"></path>
					<text x="12" y="14" text-anchor="middle" fill="#fff" font-size="12">♪</text>
				</svg> Upcoming
			</span>
			<span class="legend-item">
				<svg class="pin past" width="18" height="24" viewBox="0 0 24 32" aria-hidden="true">
					<path d="M12 31C12 31 22 19 22 11A10 10 0 1 0 2 11C2 19 12 31 12 31Z" stroke="#fff" stroke-width="2"></path>
					<text x="12" y="14" text-anchor="middle" fill="#fff" font-size="12">♪</text>
				</svg> Recent
			</span>
		</div>
	</div>
	<div id="perf-map" class="perf-map" role="img" aria-label="Performance locations">
		<p class="map-fallback">Loading map…</p>
	</div>
</section>

<script is:inline>
	(function () {
		var el = document.getElementById("perf-map");
		if (!el) return;

		var LEAFLET_CSS = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
		var LEAFLET_JS = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";

		function loadCss(href) {
			if (document.querySelector('link[href="' + href + '"]')) return;
			var link = document.createElement("link");
			link.rel = "stylesheet";
			link.href = href;
			document.head.appendChild(link);
		}

		function loadScript(src) {
			return new Promise(function (resolve, reject) {
				if (window.L) return resolve();
				var existing = document.querySelector('script[src="' + src + '"]');
				if (existing) {
					existing.addEventListener("load", function () {
						resolve();
					});
					existing.addEventListener("error", reject);
					return;
				}
				var s = document.createElement("script");
				s.src = src;
				s.onload = function () {
					resolve();
				};
				s.onerror = reject;
				document.head.appendChild(s);
			});
		}

		function escapeHtml(s) {
			return String(s == null ? "" : s).replace(/[&<>"']/g, function (c) {
				return {
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#39;",
				}[c];
			});
		}

		function hideSection() {
			var section = el.closest(".map-section");
			if (section) section.style.display = "none";
		}

		async function init() {
			var data;
			try {
				var res = await fetch("/api/performance-locations.json");
				data = await res.json();
			} catch (e) {
				hideSection();
				return;
			}

			var points = (data && data.points) || [];
			if (points.length === 0) {
				hideSection();
				return;
			}

			loadCss(LEAFLET_CSS);
			try {
				await loadScript(LEAFLET_JS);
			} catch (e) {
				hideSection();
				return;
			}
			var L = window.L;
			if (!L) {
				hideSection();
				return;
			}

			el.innerHTML = "";
			var map = L.map(el, { scrollWheelZoom: false });
			L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
				attribution:
					'&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
				maxZoom: 19,
			}).addTo(map);

			var colors = { upcoming: "#6d28d9", past: "#ec4899" };

			// A teardrop drop pin with a white music note inside — the same
			// mark as the legend swatch. Returned as a Leaflet divIcon
			// anchored at the point of the drop.
			function noteIcon(kind) {
				var fill = colors[kind] || colors.past;
				var html =
					'<svg width="30" height="40" viewBox="0 0 24 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">' +
					'<path d="M12 31C12 31 22 19 22 11A10 10 0 1 0 2 11C2 19 12 31 12 31Z" fill="' +
					fill +
					'" stroke="#ffffff" stroke-width="2"/>' +
					'<text x="12" y="15" text-anchor="middle" fill="#ffffff" font-size="13">♪</text>' +
					"</svg>";
				return L.divIcon({
					html: html,
					className: "note-pin",
					iconSize: [30, 40],
					iconAnchor: [15, 39],
					popupAnchor: [0, -34],
				});
			}

			var latlngs = [];
			points.forEach(function (p) {
				if (typeof p.lat !== "number" || typeof p.lng !== "number") return;
				var marker = L.marker([p.lat, p.lng], {
					icon: noteIcon(p.kind),
				}).addTo(map);
				var place = [p.venue, p.location].filter(Boolean).join(", ");
				marker.bindPopup(
					"<strong>" +
						escapeHtml(p.title) +
						"</strong><br>" +
						(place ? "<span>" + escapeHtml(place) + "</span><br>" : "") +
						'<a href="/performances/' +
						encodeURIComponent(p.slug) +
						'">View details &rarr;</a>',
				);
				latlngs.push([p.lat, p.lng]);
			});

			if (latlngs.length === 0) {
				hideSection();
				return;
			}
			if (latlngs.length === 1) {
				map.setView(latlngs[0], 12);
			} else {
				map.fitBounds(latlngs, { padding: [40, 40] });
			}
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init);
		} else {
			init();
		}
	})();
</script>

<style>
	.map-section {
		margin: 2.5em 0;
	}
	.map-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
		flex-wrap: wrap;
		margin-bottom: 0.8em;
	}
	.map-head h2 {
		margin: 0;
	}
	.legend {
		display: flex;
		gap: 1.1em;
		font-size: 0.9em;
		font-weight: 700;
		color: rgb(var(--gray-dark));
	}
	.legend-item {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
	}
	.legend .pin {
		display: inline-block;
		vertical-align: middle;
		filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.2));
	}
	.pin.up path {
		fill: #6d28d9;
	}
	.pin.past path {
		fill: #ec4899;
	}
	/* Leaflet gives divIcons a white box + border by default; strip it so the
	   drop pin sits cleanly on the map. */
	:global(.note-pin) {
		background: transparent;
		border: 0;
		filter: drop-shadow(0 2px 2px rgba(0, 0, 0, 0.3));
	}
	.perf-map {
		height: 420px;
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		background: var(--brand-grad-soft);
		/* Contain Leaflet's internal z-indexes (panes/controls reach ~1000) inside
		   the map's own stacking context, so they never paint over the sticky
		   header (z-index 50). */
		position: relative;
		z-index: 0;
		isolation: isolate;
	}
	.map-fallback {
		display: grid;
		place-items: center;
		height: 100%;
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 560px) {
		.perf-map {
			height: 320px;
		}
	}
</style>
